rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return signedIn() && request.auth.uid == uid;
    }

    function isAuthor() {
      return signedIn()
        && request.resource.data.authorId == request.auth.uid;
    }

    function isExistingAuthor() {
      return signedIn()
        && resource.data.authorId == request.auth.uid;
    }

    function isInteractionCounterUpdate() {
      return signedIn()
        && request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(["reactionCounts", "validationSummary", "commentCount", "updatedAt"]);
    }

    function ownsInteractionDoc(docId) {
      return signedIn() && docId == request.auth.uid;
    }

    function ownsCreatedComment() {
      return signedIn()
        && request.resource.data.authorId == request.auth.uid
        && request.resource.data.body is string
        && request.resource.data.body.size() > 0
        && request.resource.data.body.size() <= 1000;
    }

    function ownsExistingComment() {
      return signedIn() && resource.data.authorId == request.auth.uid;
    }

    function existingReplyCount() {
      return resource.data.replyCount is number ? resource.data.replyCount : 0;
    }

    function existingRepliesSize() {
      return resource.data.replies is list ? resource.data.replies.size() : 0;
    }

    function isValidReplyTimestampUpdate() {
      return !request.resource.data.diff(resource.data).affectedKeys()
          .hasAny(["updatedAt"])
        || request.resource.data.updatedAt is timestamp;
    }

    function isValidReplyCountUpdate() {
      return !request.resource.data.diff(resource.data).affectedKeys()
          .hasAny(["replyCount"])
        || (
          request.resource.data.replyCount is number
          && request.resource.data.replyCount >= existingReplyCount()
          && request.resource.data.replyCount <= existingReplyCount() + 1
        );
    }

    function isValidEmbeddedRepliesUpdate() {
      return !request.resource.data.diff(resource.data).affectedKeys()
          .hasAny(["replies"])
        || (
          request.resource.data.replies is list
          && request.resource.data.replies.size() >= existingRepliesSize()
          && request.resource.data.replies.size() <= existingRepliesSize() + 1
        );
    }

    function isReplyMetadataUpdate() {
      return signedIn()
        && request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(["replyCount", "updatedAt", "replies"])
        && isValidReplyCountUpdate()
        && isValidEmbeddedRepliesUpdate()
        && isValidReplyTimestampUpdate();
    }

    match /users/{userId} {
      allow read: if signedIn();
      allow create, update: if isOwner(userId);
      allow delete: if false;

      match /notificationTokens/{tokenId} {
        allow read: if isOwner(userId);
        allow create, update, delete: if isOwner(userId)
          && request.resource.data.userId == request.auth.uid;
      }
    }

    match /fieldRecords/{recordId} {
      allow read: if signedIn();
      allow create: if isAuthor();
      allow update: if isInteractionCounterUpdate();
      allow delete: if false;

      match /reactions/{userId} {
        allow read: if signedIn();
        allow create, update, delete: if ownsInteractionDoc(userId);
      }

      match /confirmations/{userId} {
        allow read: if signedIn();
        allow create, update, delete: if ownsInteractionDoc(userId);
      }

      match /comments/{commentId} {
        allow read: if signedIn();
        allow create: if ownsCreatedComment();
        allow update: if ownsExistingComment() || isReplyMetadataUpdate();
        allow delete: if ownsExistingComment();

        match /replies/{replyId} {
          allow read: if signedIn();
          allow create: if ownsCreatedComment();
          allow update, delete: if ownsExistingComment();
        }
      }
    }

    match /publicFeed/{postId} {
      allow read: if signedIn();
      allow create: if isAuthor();
      allow update: if isInteractionCounterUpdate();
      allow delete: if false;

      match /reactions/{userId} {
        allow read: if signedIn();
        allow create, update, delete: if ownsInteractionDoc(userId);
      }

      match /confirmations/{userId} {
        allow read: if signedIn();
        allow create, update, delete: if ownsInteractionDoc(userId);
      }

      match /comments/{commentId} {
        allow read: if signedIn();
        allow create: if ownsCreatedComment();
        allow update: if ownsExistingComment() || isReplyMetadataUpdate();
        allow delete: if ownsExistingComment();

        match /replies/{replyId} {
          allow read: if signedIn();
          allow create: if ownsCreatedComment();
          allow update, delete: if ownsExistingComment();
        }
      }
    }

    match /events/{eventId} {
      allow read: if signedIn();
      // El autor crea el evento (y queda auto-inscrito como participante).
      // El cupo (capacity) y el conteo de inscritos solo se modifican vía
      // Cloud Functions (join_event / leave_event / update_event).
      allow create: if isAuthor();
      allow update, delete: if false;

      match /participants/{userId} {
        // Inscritos visibles para todos los autenticados; el autor del evento
        // crea su propio doc al publicar (auto-inscripción). Las altas/bajas
        // del resto pasan por la Cloud Function join_event / leave_event.
        allow read: if signedIn();
        allow create: if ownsInteractionDoc(userId)
          && request.resource.data.userId == request.auth.uid;
        allow update, delete: if false;
      }
    }

    match /tours/{tourId} {
      allow read: if signedIn();
      allow create: if isAuthor();
      allow update, delete: if false;
    }

    match /tracks/{trackId} {
      allow read: if signedIn();
      // El autor crea su recorrido y puede reescribirlo (reintentos offline).
      allow create: if isAuthor();
      allow update: if isExistingAuthor() && isAuthor();
      allow delete: if false;
    }

    match /userStats/{userId} {
      allow read: if signedIn();
      allow write: if isOwner(userId);
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
